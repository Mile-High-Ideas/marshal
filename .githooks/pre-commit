#!/usr/bin/env bash
#
# marshal pre-commit hook -- lint staged scripts before they ship.
#
#   * shell scripts   (.sh/.command/.bash) -> shellcheck
#   * Windows scripts (.ps1/.bat/.cmd)     -> encoding + line-ending sanity,
#                                             plus a real PowerShell parse when
#                                             pwsh is installed.
#
# The Windows checks exist because a \\Mac\... shared capture.ps1 shipped with
# em-dashes: Windows PowerShell 5.1 reads a no-BOM file as ANSI, mangles them
# into invalid tokens, and the script won't parse. Keeping these files ASCII
# (or UTF-8-BOM) and .bat/.cmd CRLF stops that from recurring.
#
# Shared with the team: wired via `core.hooksPath=.githooks`, which .envrc sets
# on directory entry (run `direnv allow` once to activate). Bypass a single
# commit with `git commit --no-verify` if you must.

set -euo pipefail

grn=$'\033[1;32m'; yel=$'\033[1;33m'; red=$'\033[1;31m'; rst=$'\033[0m'
ok()   { printf '%s[pre-commit]%s %s\n' "$grn" "$rst" "$*"; }
warn() { printf '%s[pre-commit]%s %s\n' "$yel" "$rst" "$*" >&2; }
fail() { printf '%s[pre-commit]%s %s\n' "$red" "$rst" "$*" >&2; }

# Partition staged (added/copied/modified) files by kind. NUL-delimited to
# survive the spaces in the "N. Name.command" launcher filenames.
shell_files=(); win_files=()
while IFS= read -r -d '' f; do
  case "$f" in
    *.sh | *.command | *.bash)  shell_files+=("$f") ;;
    *.ps1 | *.bat | *.cmd)      win_files+=("$f") ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACM -z)

status=0

# --- shell scripts -----------------------------------------------------------
if [ ${#shell_files[@]} -gt 0 ]; then
  if command -v shellcheck >/dev/null 2>&1; then
    # --severity=warning: fail on warnings + errors, let info/style nits through
    # (repo-wide suppressions live in .shellcheckrc).
    if shellcheck --severity=warning "${shell_files[@]}"; then
      ok "shellcheck passed (${#shell_files[@]} file(s))."
    else
      fail "shellcheck found issues above."
      status=1
    fi
  else
    warn "shellcheck not found -- skipping shell lint. Install: brew install shellcheck"
  fi
fi

# --- Windows scripts ---------------------------------------------------------
if [ ${#win_files[@]} -gt 0 ]; then
  win_bad=0

  for f in "${win_files[@]}"; do
    # 1. Encoding. A UTF-8 BOM (EF BB BF) makes PowerShell 5.1 decode UTF-8
    #    correctly, so a BOM'd file may legitimately hold non-ASCII. Without a
    #    BOM the file must be pure ASCII: any byte outside tab/CR/LF/printable
    #    is a mojibake risk under 5.1's ANSI fallback.
    if [ "$(head -c 3 "$f" | od -An -tx1 | tr -d ' \n')" = "efbbbf" ]; then
      : # UTF-8 BOM present -- safe for PowerShell 5.1
    elif ! LC_ALL=C perl -ne 'exit 1 if /[^\x09\x0A\x0D\x20-\x7E]/' "$f"; then
      fail "$f: non-ASCII byte(s) and no UTF-8 BOM -- PowerShell 5.1 will mangle this. Keep it ASCII, or save it with a UTF-8 BOM."
      win_bad=1
    fi

    # 2. Line endings. cmd.exe parses .bat/.cmd if-blocks reliably only with
    #    CRLF. (.ps1 is fine with LF, so it is exempt.)
    case "$f" in
      *.bat | *.cmd)
        if ! perl -0777 -ne 'exit 1 if /(?<!\r)\n/' "$f"; then
          fail "$f: bare LF line endings -- convert to CRLF for cmd.exe (perl -i -pe 's/\\r?\\n/\\r\\n/' \"$f\")."
          win_bad=1
        fi
        ;;
    esac
  done

  # 3. A real PowerShell parse, when pwsh is available. Catches syntax typos the
  #    byte-level checks can't. Skipped (not failed) if pwsh is not installed.
  if command -v pwsh >/dev/null 2>&1; then
    for f in "${win_files[@]}"; do
      case "$f" in *.ps1) ;; *) continue ;; esac
      # Pass the path via env, not a trailing arg: `-Command "<string>"` does
      # not bind trailing args to $args, it parses them as code.
      if ! PS_TARGET="$f" pwsh -NoProfile -NonInteractive -Command '
        $errs = $null
        [void][System.Management.Automation.Language.Parser]::ParseFile($env:PS_TARGET, [ref]$null, [ref]$errs)
        if ($errs) { $errs | ForEach-Object { [Console]::Error.WriteLine($_.ToString()) }; exit 1 }
      '; then
        fail "$f: PowerShell parse errors above."
        win_bad=1
      fi
    done
  else
    warn "pwsh not found -- skipping PowerShell parse. Install: brew install powershell"
  fi

  if [ "$win_bad" -eq 0 ]; then
    ok "windows-script checks passed (${#win_files[@]} file(s))."
  else
    status=1
  fi
fi

if [ "$status" -ne 0 ]; then
  fail "commit blocked. Fix the issues above, or override with: git commit --no-verify"
  exit 1
fi
